### ----------------- MEETINGS ------------------

###
# @name List meetings
GET http://localhost:3000/api/meetings
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name Create meeting
POST http://localhost:3000/api/meetings
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "title": "Executive Committee Meeting",
  "type": "EC_MEETING",
  "scheduledAt": "2026-06-15T10:00:00Z",
  "venue": "Conference Room A",
  "agendaItems": [
    {
      "order": 1,
      "title": "Approval of Previous Minutes",
      "description": "Review and approve the minutes from the last EC meeting"
    },
    {
      "order": 2,
      "title": "Financial Report Q1",
      "description": "Presentation of quarterly financial statements"
    },
    {
      "order": 3,
      "title": "Member Applications",
      "description": "Review new membership applications for approval"
    }
  ]
}

###
# @name Get meeting details
GET http://localhost:3000/api/meetings/{{meetingId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name Update meeting
PATCH http://localhost:3000/api/meetings/{{meetingId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "title": "Updated Meeting Title",
  "venue": "New Venue"
}

###
# @name Delete meeting
DELETE http://localhost:3000/api/meetings/{{meetingId}}
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

### ----------------- MEETING ATTENDEES ------------------

###
# @name List meeting attendees
GET http://localhost:3000/api/meetings/{{meetingId}}/attendees
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name Assign single attendee
POST http://localhost:3000/api/meetings/{{meetingId}}/attendees
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "userId": "{{userId}}",
  "attendeeRole": "OPTIONAL"
}

###
# @name Bulk assign attendees
PUT http://localhost:3000/api/meetings/{{meetingId}}/attendees
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "userIds": ["uuid-1", "uuid-2", "uuid-3"],
  "attendeeRole": "REQUIRED"
}

###
# @name  meeting agenda
GET http://localhost:3000/api/meetings/{{meetingId}}/agenda
Content-Type: application/json
Authorization: Bearer {{TOKEN}}


###
# @name Update attendee RSVP
PATCH http://localhost:3000/api/meetings/{{meetingId}}/rsvp
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "rsvpStatus": "ACCEPTED",
  "rsvpNote": "I will attend"
}

###
# @name Remove attendee
DELETE http://localhost:3000/api/meetings/{{meetingId}}/rsvp
Content-Type: application/json
Authorization: Bearer {{TOKEN}}
