### ----------------- SUBSCRIPTIONS & PAYMENTS ------------------

###
# @name Get Subscription Plans
GET {{NEXT_PUBLIC_API_BASE_URL}}/subscriptions/plans
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name Create Subscription Plan
POST {{NEXT_PUBLIC_API_BASE_URL}}/subscriptions/plans
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "name": "Membership",
  "description": "Full access to all association benefits",
  "amount": 5000,
  "currency": "INR",
  "billingCycle": "YEARLY",
  "features": {
    "events": true,
    "voting": true
  }
}

###
# @name Subscribe to Plan
POST {{NEXT_PUBLIC_API_BASE_URL}}/subscriptions/subscribe
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "planId": "REPLACE_WITH_PLAN_ID"
}

###
# @name Waive Subscription
POST {{NEXT_PUBLIC_API_BASE_URL}}/subscriptions/waive
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "subscriptionId": "REPLACE_WITH_SUBSCRIPTION_ID",
  "reason": "Exempted by the board"
}

###
# @name Get Payment History
GET {{NEXT_PUBLIC_API_BASE_URL}}/payments/history?page=1&pageSize=20
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

###
# @name Create Payment Order
POST {{NEXT_PUBLIC_API_BASE_URL}}/payments/order
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "userId": "{{userId}}",
  "amount": 5000,
  "notes": "Monthly contribution for May 2026"
}

###
# @name Verify Payment
POST {{NEXT_PUBLIC_API_BASE_URL}}/payments/verify
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "razorpayOrderId": "order_12345",
  "razorpayPaymentId": "pay_12345",
  "razorpaySignature": "sig_12345"
}

###
# @name Record Manual Payment
POST {{NEXT_PUBLIC_API_BASE_URL}}/payments/record
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "userId": "{{userId}}",
  "amount": 5000,
  "method": "CASH",
  "notes": "Paid in cash at the office",
  "receiptNumber": "REC-001",
  "referenceNumber": "REF-12345"
}

###
# @name Generate Contributions
POST {{NEXT_PUBLIC_API_BASE_URL}}/payments/contributions
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "year": 2026,
  "month": 5
}

###
# @name Waive Contribution
PATCH {{NEXT_PUBLIC_API_BASE_URL}}/payments/contributions
Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "contributionPeriodId": "REPLACE_WITH_UUID",
  "reason": "Hardship case"
}

###
# @name Payment Webhook
POST {{NEXT_PUBLIC_API_BASE_URL}}/payments/webhook
Content-Type: application/json
x-razorpay-signature: REPLACE_WITH_HMAC

{
  "entity": "event",
  "account_id": "acc_BFQ7uS97yRUrSg",
  "event": "payment.captured",
  "contains": ["payment"],
  "payload": {
    "payment": {
      "entity": {
        "id": "pay_DESLFWSkdsc9",
        "amount": 5000,
        "currency": "INR",
        "status": "captured",
        "order_id": "order_DESLFWSkdsc9",
        "notes": {
          "associationId": "{{associationsId}}"
        }
      }
    }
  },
  "created_at": 1400826750
}

