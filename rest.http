Content-Type: application/json
Authorization: Bearer {{TOKEN}}

{
  "slug": "mpsc",
  "name": "Delhi Cricket Association",
  "state": "Delhi",
  "country": "IN",
  "contactEmail": "contact@delhicricket.org",
  "primaryColor": "#1e40af",
  "secondaryColor": "#f59e0b"
}

